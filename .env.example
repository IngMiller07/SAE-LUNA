# Plantilla de variables de entorno para el proyceto SAE.
# Instrucciones:
# 1. Haz una copia de este archivo y renombrala a ".env" (sin nombre, solo extension .env)
# 2. Pega tus claves reales aquí abajo. (¡No subas el archivo .env a GitHub!)

# API KEY del Bot de Telegram (Obtenida desde Midas o BotFather)
TELEGRAM_TOKEN=tu_token_de_telegram_aqui

# API KEY de Roboflow (Obtenido desde la cuenta de Roboflow Workspace Settings)
ROBOFLOW_API_KEY=tu_token_de_roboflow_aqui
